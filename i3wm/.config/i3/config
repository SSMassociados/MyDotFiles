include ~/.config/i3/modules/monitors.conf
include ~/.config/i3/modules/windowsrule.conf
include ~/.config/i3/modules/binds.conf
include ~/.config/i3/modules/misc.conf
include ~/.config/i3/modules/autostart.conf

